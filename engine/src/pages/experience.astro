---
import profileData from '../data/melat-tekie.json';
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>Melat Tekie — Beyond My Resume</title>
    <meta name="description" content="Melat Tekie — full-stack developer portfolio. Explore my journey, skills, and projects through an interactive 3D experience." />
    <meta property="og:title" content="Melat Tekie — Beyond My Resume" />
    <meta property="og:description" content="Discover my work. Imagine what's possible for yours." />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='6' fill='%231a1410'/%3E%3Ctext x='16' y='23' font-family='Georgia, serif' font-size='19' font-weight='bold' fill='%23ffb877' text-anchor='middle'%3EM%3C/text%3E%3C/svg%3E" />
    <style>
      body { margin: 0; overflow: hidden; font-family: sans-serif; }
      #experience-container { width: 100vw; height: calc(var(--vh, 1vh) * 100); }

      #loading-overlay {
        position: fixed;
        inset: 0;
        background: #1a1410;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 100;
        transition: opacity 0.5s ease;
      }
      #loading-overlay.hidden {
        opacity: 0;
        pointer-events: none;
      }
      #loading-overlay p {
        font-family: Georgia, 'Times New Roman', serif;
        font-size: 16px;
        color: #e8c9a0;
        letter-spacing: 0.05em;
      }

      #onboarding-hint {
        position: absolute;
        top: 110px;
        left: 50%;
        transform: translateX(-50%);
        background: rgba(15, 10, 7, 0.85);
        border: 1px solid rgba(255, 184, 119, 0.25);
        border-radius: 20px;
        padding: 8px 18px;
        font-size: 12px;
        color: #e8c9a0;
        z-index: 15;
        opacity: 0;
        transition: opacity 0.5s ease;
      }
      #onboarding-hint.visible {
        opacity: 1;
      }

      #site-header {
        position: absolute;
        top: 36px;
        left: 50%;
        transform: translateX(-50%);
        text-align: center;
        z-index: 10;
        pointer-events: none;
      }
      #site-header h1 {
        font-family: Georgia, 'Times New Roman', serif;
        font-size: 30px;
        font-weight: 400;
        color: #ffd9ad;
        margin: 0 0 6px;
      }
      #site-header p {
        font-size: 13px;
        color: #c9b48d;
        margin: 0;
      }

      #chapter-nav {
        position: absolute;
        bottom: 24px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        gap: 6px;
        z-index: 10;
        max-width: calc(100vw - 24px);
        overflow-x: auto;
        padding-bottom: 2px;
        scrollbar-width: none;
      }
      #chapter-nav::-webkit-scrollbar {
        display: none;
      }
      .chapter-btn {
        display: flex;
        align-items: center;
        gap: 6px;
        background: rgba(255, 255, 255, 0.1);
        color: #e8c9a0;
        border: 1px solid rgba(255, 184, 119, 0.3);
        border-radius: 20px;
        padding: 8px 14px;
        font-size: 11.5px;
        white-space: nowrap;
        cursor: pointer;
        flex-shrink: 0;
      }
      .chapter-btn svg {
        width: 13px;
        height: 13px;
        flex-shrink: 0;
      }
      .chapter-btn.active {
        background: #ffb877;
        color: #1a1410;
      }

      #content-eyebrow {
        font-size: 10px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #ffbb70;
        margin: 0 0 6px;
      }

      #content-panel {
        position: absolute;
        top: 150px;
        left: 16px;
        width: calc(100vw - 32px);
        max-width: 400px;
        overflow-y: auto;
        text-align: left;
        color: #f3e4c8;
        opacity: 0;
        transition: opacity 0.6s ease;
        z-index: 10;
        padding: 18px 22px;
        background: rgba(15, 10, 7, 0.92);
        border: 1px solid rgba(255, 184, 119, 0.2);
        border-radius: 10px;
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.4);
      }
      #content-panel.visible {
        opacity: 1;
      }
      #content-title {
        font-family: Georgia, 'Times New Roman', serif;
        font-size: 19px;
        font-weight: 400;
        margin: 0 0 3px;
        color: #ffd9ad;
      }
      #content-subtitle {
        font-size: 11px;
        color: #c9b48d;
        margin: 0 0 18px;
      }
      #content-underline {
        width: 40px;
        height: 2px;
        background: rgba(255, 184, 119, 0.4);
        margin: -8px 0 20px;
      }

      .about-text {
        font-family: Georgia, 'Times New Roman', serif;
        font-size: 14px;
        color: #f0dfc0;
        line-height: 1.7;
        margin: 0;
      }

      .skills-text {
        font-size: 13px;
        color: #f0dfc0;
        line-height: 1.9;
      }

      .contact-underline {
        width: 40px;
        height: 2px;
        background: rgba(255, 184, 119, 0.4);
        margin: 10px 0 20px;
      }
      .contact-columns {
        display: flex;
        margin-bottom: 18px;
      }
      .contact-col {
        flex: 1;
        text-align: center;
        padding: 0 8px;
        border-right: 1px solid rgba(255, 184, 119, 0.15);
        text-decoration: none;
        display: block;
      }
      .contact-col:last-child {
        border-right: none;
      }
      .contact-col-icon {
        display: flex;
        justify-content: center;
        margin-bottom: 8px;
      }
      .contact-col-label {
        font-size: 12px;
        font-weight: 600;
        color: #f0dfc0;
        margin: 0 0 4px;
      }
      .contact-col-value {
        font-size: 11px;
        color: #c9b48d;
        margin: 0;
        word-break: break-word;
        line-height: 1.4;
      }
      .contact-footer {
        display: flex;
        align-items: center;
        gap: 8px;
        border-top: 1px solid rgba(255, 184, 119, 0.15);
        padding-top: 14px;
        font-family: Georgia, 'Times New Roman', serif;
        font-style: italic;
        font-size: 12px;
        color: #c9b48d;
      }

      .simple-list { display: flex; flex-direction: column; gap: 10px; }
      .simple-row { font-size: 13px; color: #f0dfc0; }
      .simple-link {
        font-size: 13px;
        color: #ffd9ad;
        text-decoration: none;
        border-bottom: 1px solid rgba(255, 217, 173, 0.3);
        padding-bottom: 1px;
      }
      .simple-link:hover {
        border-bottom-color: #ffd9ad;
      }

      .journal-entry {
        margin-bottom: 14px;
        padding-bottom: 14px;
        border-bottom: 1px solid rgba(255, 217, 173, 0.1);
      }
      .journal-entry:last-child {
        margin-bottom: 0;
        padding-bottom: 0;
        border-bottom: none;
      }
      .journal-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
        cursor: pointer;
      }
      .journal-header-text { flex: 1; }
      .journal-toggle {
        width: 20px;
        height: 20px;
        border-radius: 50%;
        border: 1px solid rgba(255, 187, 112, 0.4);
        color: #ffbb70;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        line-height: 1;
        flex-shrink: 0;
        margin-top: 2px;
        transition: transform 0.3s ease;
      }
      .journal-entry.expanded .journal-toggle {
        transform: rotate(45deg);
      }
      .journal-dates {
        font-size: 10px;
        letter-spacing: 0.08em;
        color: #ffbb70;
        text-transform: uppercase;
        margin: 0 0 4px;
      }
      .journal-heading {
        font-family: Georgia, 'Times New Roman', serif;
        font-size: 15px;
        color: #ffd9ad;
        margin: 0;
      }
      .journal-heading .company {
        color: #f0dfc0;
        font-style: italic;
        font-weight: 400;
      }
      .journal-narrative-wrap {
        max-height: 0;
        overflow: hidden;
        opacity: 0;
        transition: max-height 0.35s ease, opacity 0.25s ease, margin-top 0.35s ease;
      }
      .journal-entry.expanded .journal-narrative-wrap {
        max-height: 320px;
        opacity: 1;
        margin-top: 10px;
      }
      .journal-narrative {
        font-family: Georgia, 'Times New Roman', serif;
        font-size: 13px;
        color: #e3d2af;
        line-height: 1.7;
        margin: 0;
      }

      .journey-track {
        position: relative;
        display: flex;
        gap: 12px;
        padding-bottom: 10px;
        margin-bottom: 18px;
      }
      .journey-year-chip {
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 184, 119, 0.3);
        color: #e8c9a0;
        font-size: 11px;
        font-family: sans-serif;
        padding: 6px 12px;
        border-radius: 16px;
        cursor: pointer;
        white-space: nowrap;
        transition: background 0.25s ease, color 0.25s ease, border-color 0.25s ease;
      }
      .journey-year-chip.active {
        background: #ffb877;
        color: #1a1410;
        border-color: #ffb877;
        font-weight: 600;
      }
      .journey-indicator {
        position: absolute;
        bottom: 0;
        height: 2px;
        background: #ffb877;
        border-radius: 2px;
        transition: left 0.35s ease, width 0.35s ease;
      }
      .journey-detail {
        transition: opacity 0.25s ease;
      }
    </style>
  </head>
  <body>
    <div id="loading-overlay">
      <p>Loading the experience...</p>
    </div>
    <header id="site-header">
      <h1>Beyond My Resume</h1>
      <p>Discover my work. Imagine what's possible for yours.</p>
    </header>
    <div id="onboarding-hint">Click any object, or use the nav below to explore</div>
    <div id="content-panel">
      <p id="content-eyebrow"></p>
      <h2 id="content-title"></h2>
      <p id="content-subtitle"></p>
      <div id="content-underline"></div>
      <div id="content-body"></div>
    </div>
    <div id="experience-container"></div>
    <nav id="chapter-nav">
      <button class="chapter-btn" data-index="0">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 4-6 8-6s8 2 8 6"/></svg>
        About
      </button>
      <button class="chapter-btn" data-index="1">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="5" cy="19" r="1.5" fill="currentColor" stroke="none"/><circle cx="19" cy="5" r="1.5" fill="currentColor" stroke="none"/><path d="M5 19c3-5 4 3 7-2s3-6 7-9"/></svg>
        The Journey
      </button>
      <button class="chapter-btn" data-index="2">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M8 6l-5 6 5 6M16 6l5 6-5 6"/></svg>
        Skills
      </button>
      <button class="chapter-btn" data-index="3">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 7h6l2 2h10v10H3z"/></svg>
        Projects
      </button>
      <button class="chapter-btn" data-index="4">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 7l9 6 9-6"/></svg>
        Contact
      </button>
    </nav>

    <script define:vars={{ profile: profileData }}>
      window.__PROFILE__ = profile;
    </script>
    <script>
      import { initScene, addChapterMarkers, setupMarkerInteraction } from '../experience/Scene.js';
      import { createCameraController } from '../experience/CameraController.js';
      import { chapters } from '../experience/chapters.js';

      const profile = window.__PROFILE__;

      // iOS Safari's address bar shows/hides dynamically, and 100vh doesn't
      // account for that — it measures the full viewport including space
      // the toolbar is covering. This keeps a real, current measurement
      // in a CSS custom property instead, avoiding blank gaps or cut-off content.
      function setViewportHeight() {
        document.documentElement.style.setProperty('--vh', window.innerHeight * 0.01 + 'px');
      }
      setViewportHeight();
      window.addEventListener('resize', setViewportHeight);
      window.addEventListener('orientationchange', setViewportHeight);

      const container = document.getElementById('experience-container');
      const { scene, camera, renderer } = initScene(container);
      const markers = addChapterMarkers(scene, chapters);
      const cameraController = createCameraController(camera);

      let currentIndex = 0;
      let openIndex = null;

      const contentPanel = document.getElementById('content-panel');
      const contentEyebrow = document.getElementById('content-eyebrow');
      const contentTitle = document.getElementById('content-title');
      const contentSubtitle = document.getElementById('content-subtitle');
      const contentUnderline = document.getElementById('content-underline');
      Object.assign(contentUnderline.style, {
        width: '40px',
        height: '2px',
        background: 'rgba(255, 184, 119, 0.4)',
        margin: '0 0 20px',
      });
      const contentBody = document.getElementById('content-body');

      function clampPanelHeight() {
        const navBar = document.getElementById('chapter-nav');
        const panelTop = contentPanel.getBoundingClientRect().top;
        const navTop = navBar.getBoundingClientRect().top;
        const available = navTop - panelTop - 20;
        contentPanel.style.maxHeight = Math.max(available, 100) + 'px';
      }
      window.addEventListener('resize', clampPanelHeight);

      const chapterContent = {
        about: {
          eyebrow: 'About me',
          title: profile.name,
          subtitle: profile.title,
          type: 'about',
        },
        experience: {
          eyebrow: 'Career',
          title: 'The Journey',
          subtitle: 'Click a year to see what happened',
          type: 'journey',
          entries: profile.experience || [],
        },
        skills: {
          eyebrow: 'What I work with',
          title: 'Skills',
          subtitle: 'Tools I reach for daily',
          type: 'skills',
        },
        projects: {
          eyebrow: 'Selected work',
          title: 'Projects',
          subtitle: 'A few things I\u2019ve built',
          type: 'journal',
          entries: profile.projects.map((p) => ({
            role: p.name,
            company: p.techStack.join(' \u00b7 '),
            dates: '',
            narrative: p.description,
          })),
        },
        contact: {
          eyebrow: 'Get in touch',
          title: 'I\u2019d love to hear from you.',
          subtitle: '',
          type: 'contact',
        },
      };

      function renderJourney(entries) {
        const container = document.createElement('div');

        const track = document.createElement('div');
        track.className = 'journey-track';

        const indicator = document.createElement('div');
        indicator.className = 'journey-indicator';

        const chips = entries.map((entry, i) => {
          const chip = document.createElement('button');
          chip.className = 'journey-year-chip';
          chip.type = 'button';
          chip.textContent = entry.dates.split(' ')[0];
          chip.title = entry.dates;
          Object.assign(chip.style, {
            background: 'rgba(255, 255, 255, 0.1)',
            border: '1px solid rgba(255, 184, 119, 0.3)',
            color: '#e8c9a0',
            fontSize: '11px',
            fontFamily: 'sans-serif',
            padding: '6px 12px',
            borderRadius: '16px',
            cursor: 'pointer',
            whiteSpace: 'nowrap',
            transition: 'background 0.25s ease, color 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease, transform 0.25s ease',
          });
          track.appendChild(chip);
          return chip;
        });
        track.appendChild(indicator);

        const detail = document.createElement('div');
        detail.className = 'journey-detail';

        const detailDates = document.createElement('p');
        detailDates.className = 'journal-dates';
        const detailHeading = document.createElement('p');
        detailHeading.className = 'journal-heading';
        const detailNarrative = document.createElement('p');
        detailNarrative.className = 'journal-narrative';

        detail.appendChild(detailDates);
        detail.appendChild(detailHeading);
        detail.appendChild(detailNarrative);

        function selectYear(index) {
          chips.forEach((chip, i) => {
            const isActive = i === index;
            chip.classList.toggle('active', isActive);
            Object.assign(chip.style, {
              background: isActive ? '#ffb877' : 'rgba(255, 255, 255, 0.1)',
              color: isActive ? '#1a1410' : '#e8c9a0',
              borderColor: isActive ? '#ffb877' : 'rgba(255, 184, 119, 0.3)',
              fontWeight: isActive ? '700' : '400',
              boxShadow: isActive ? '0 0 10px 2px rgba(255, 184, 119, 0.5)' : 'none',
              transform: isActive ? 'scale(1.05)' : 'scale(1)',
            });
          });

          const chip = chips[index];
          indicator.style.left = chip.offsetLeft + 'px';
          indicator.style.width = chip.offsetWidth + 'px';

          const entry = entries[index];
          detail.style.opacity = '0';
          setTimeout(() => {
            detailDates.textContent = entry.dates;
            detailHeading.textContent = '';
            detailHeading.textContent = entry.role;
            if (entry.company) {
              const companySpan = document.createElement('span');
              companySpan.className = 'company';
              companySpan.textContent = ' — ' + entry.company;
              detailHeading.appendChild(companySpan);
            }
            detailNarrative.textContent = entry.narrative;
            detail.style.opacity = '1';
          }, 150);
        }

        chips.forEach((chip, i) => {
          chip.addEventListener('click', () => selectYear(i));
        });

        container.appendChild(track);
        container.appendChild(detail);

        const downloadLink = document.createElement('a');
        downloadLink.href = '/resume.pdf';
        downloadLink.download = 'Melat-Tekie-Resume.pdf';
        Object.assign(downloadLink.style, {
          display: 'inline-flex',
          alignItems: 'center',
          gap: '8px',
          marginTop: '18px',
          padding: '9px 16px',
          background: 'rgba(255, 184, 119, 0.12)',
          border: '1px solid rgba(255, 184, 119, 0.35)',
          borderRadius: '20px',
          color: '#ffd9ad',
          fontSize: '12px',
          fontWeight: '600',
          textDecoration: 'none',
          transition: 'background 0.25s ease, border-color 0.25s ease',
        });
        downloadLink.innerHTML =
          '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#ffd9ad" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12m0 0l-4-4m4 4l4-4"/><path d="M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2"/></svg><span>Download Resume</span>';
        downloadLink.addEventListener('mouseenter', () => {
          downloadLink.style.background = 'rgba(255, 184, 119, 0.22)';
          downloadLink.style.borderColor = 'rgba(255, 184, 119, 0.6)';
        });
        downloadLink.addEventListener('mouseleave', () => {
          downloadLink.style.background = 'rgba(255, 184, 119, 0.12)';
          downloadLink.style.borderColor = 'rgba(255, 184, 119, 0.35)';
        });
        container.appendChild(downloadLink);

        container.__selectDefault = () => selectYear(entries.length - 1);

        return container;
      }

      function renderJournal(entries) {
        const wrap = document.createElement('div');
        entries.forEach((entry) => {
          const item = document.createElement('div');
          item.className = 'journal-entry';

          const header = document.createElement('div');
          header.className = 'journal-header';

          const headerText = document.createElement('div');
          headerText.className = 'journal-header-text';

          if (entry.dates) {
            const dates = document.createElement('p');
            dates.className = 'journal-dates';
            dates.textContent = entry.dates;
            headerText.appendChild(dates);
          }

          const heading = document.createElement('p');
          heading.className = 'journal-heading';
          const folderIcon = document.createElement('span');
          Object.assign(folderIcon.style, {
            display: 'inline-flex',
            verticalAlign: 'middle',
            marginRight: '6px',
          });
          folderIcon.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#ffb877" stroke-width="2" stroke-linecap="round"><path d="M3 7h6l2 2h10v10H3z"/></svg>';
          heading.appendChild(folderIcon);
          const headingText = document.createElement('span');
          headingText.textContent = entry.role;
          heading.appendChild(headingText);
          if (entry.company) {
            const companySpan = document.createElement('span');
            companySpan.className = 'company';
            companySpan.textContent = ' — ' + entry.company;
            heading.appendChild(companySpan);
          }
          headerText.appendChild(heading);

          const toggle = document.createElement('div');
          Object.assign(toggle.style, {
            width: '20px',
            height: '20px',
            borderRadius: '50%',
            border: '1px solid rgba(255, 187, 112, 0.4)',
            color: '#ffbb70',
            display: 'flex',
            alignItems: 'center',
            justifyContent: 'center',
            fontSize: '13px',
            lineHeight: '1',
            flexShrink: '0',
            marginTop: '2px',
            transition: 'transform 0.3s ease',
          });
          toggle.textContent = '+';

          header.appendChild(headerText);
          header.appendChild(toggle);

          const narrativeWrap = document.createElement('div');
          Object.assign(narrativeWrap.style, {
            maxHeight: '0',
            overflow: 'hidden',
            opacity: '0',
            transition: 'max-height 0.35s ease, opacity 0.25s ease, margin-top 0.35s ease',
          });
          const narrative = document.createElement('p');
          narrative.className = 'journal-narrative';
          narrative.textContent = entry.narrative;
          narrativeWrap.appendChild(narrative);

          let isExpanded = false;
          header.addEventListener('click', () => {
            isExpanded = !isExpanded;
            toggle.style.transform = isExpanded ? 'rotate(45deg)' : 'rotate(0deg)';
            if (isExpanded) {
              narrativeWrap.style.maxHeight = narrativeWrap.scrollHeight + 40 + 'px';
              narrativeWrap.style.opacity = '1';
              narrativeWrap.style.marginTop = '10px';
            } else {
              narrativeWrap.style.maxHeight = '0';
              narrativeWrap.style.opacity = '0';
              narrativeWrap.style.marginTop = '0';
            }
            clampPanelHeight();
          });

          item.appendChild(header);
          item.appendChild(narrativeWrap);
          wrap.appendChild(item);
        });
        return wrap;
      }

      function renderSkills() {
        const wrap = document.createElement('div');
        Object.assign(wrap.style, {
          display: 'flex',
          flexWrap: 'wrap',
          gap: '8px',
        });

        profile.skills.forEach((skill) => {
          const pill = document.createElement('span');
          Object.assign(pill.style, {
            fontSize: '11px',
            fontWeight: '600',
            color: '#1a1410',
            background: '#ffd9ad',
            padding: '6px 12px',
            borderRadius: '14px',
            whiteSpace: 'nowrap',
          });
          pill.textContent = skill;
          wrap.appendChild(pill);
        });

        return wrap;
      }

      function renderAbout() {
        const wrap = document.createElement('div');

        const bio = document.createElement('p');
        bio.className = 'about-text';
        bio.textContent = profile.bio || profile.title;
        wrap.appendChild(bio);

        const footer = document.createElement('div');
        Object.assign(footer.style, {
          display: 'flex',
          alignItems: 'center',
          gap: '8px',
          borderTop: '1px solid rgba(255, 184, 119, 0.15)',
          marginTop: '16px',
          paddingTop: '14px',
          fontFamily: "Georgia, 'Times New Roman', serif",
          fontStyle: 'italic',
          fontSize: '12px',
          color: '#c9b48d',
        });
        const locationLabel = profile.contact && profile.contact.location ? profile.contact.location : '';
        footer.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#ffb877" stroke-width="2" stroke-linecap="round"><path d="M12 21s7-6.5 7-11a7 7 0 0 0-14 0c0 4.5 7 11 7 11z"/><circle cx="12" cy="10" r="2.5"/></svg><span>Based in ' + locationLabel + '</span>';
        wrap.appendChild(footer);

        return wrap;
      }

      function renderContact() {
        const wrap = document.createElement('div');

        const columns = document.createElement('div');
        Object.assign(columns.style, {
          display: 'flex',
          marginBottom: '18px',
        });
        const items = [];

        if (profile.contact.email) {
          items.push({
            href: 'mailto:' + profile.contact.email,
            label: 'Email',
            value: 'Send a message',
            icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ffb877" stroke-width="2" stroke-linecap="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 7l9 6 9-6"/></svg>',
          });
        }
        if (profile.contact.location) {
          items.push({
            href: null,
            label: 'Location',
            value: profile.contact.location,
            icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ffb877" stroke-width="2" stroke-linecap="round"><path d="M12 21s7-6.5 7-11a7 7 0 0 0-14 0c0 4.5 7 11 7 11z"/><circle cx="12" cy="10" r="2.5"/></svg>',
          });
        }
        if (profile.contact.linkedin) {
          items.push({
            href: profile.contact.linkedin,
            label: 'LinkedIn',
            value: 'Connect with me',
            icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ffb877" stroke-width="2" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M7 10v7M7 7v.01M12 17v-4a2 2 0 0 1 4 0v4M12 13v4"/></svg>',
          });
        }
        if (profile.contact.github) {
          items.push({
            href: profile.contact.github,
            label: 'GitHub',
            value: 'See my code',
            icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ffb877" stroke-width="2" stroke-linecap="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.9c0-1.1.35-1.8 1-2.4-3.35-.4-6.87-1.75-6.87-7.9 0-1.75.6-3.15 1.6-4.25-.15-.4-.7-2.05.15-4.25 0 0 1.3-.4 4.25 1.6a14.7 14.7 0 0 1 7.75 0c2.95-2 4.25-1.6 4.25-1.6.85 2.2.3 3.85.15 4.25 1 1.1 1.6 2.5 1.6 4.25 0 6.15-3.55 7.5-6.9 7.9.55.5 1 1.45 1 2.9V22"/></svg>',
          });
        }

        items.forEach((item, index) => {
          const col = document.createElement(item.href ? 'a' : 'div');
          Object.assign(col.style, {
            flex: '1',
            textAlign: 'center',
            padding: '0 8px',
            textDecoration: 'none',
            display: 'block',
            color: '#f0dfc0',
            borderRight: index < items.length - 1 ? '1px solid rgba(255, 184, 119, 0.15)' : 'none',
          });
          if (item.href) {
            col.href = item.href;
            if (item.href.startsWith('http')) {
              col.target = '_blank';
              col.rel = 'noopener noreferrer';
            }
          }

          const iconWrap = document.createElement('div');
          Object.assign(iconWrap.style, {
            display: 'flex',
            justifyContent: 'center',
            marginBottom: '8px',
          });
          iconWrap.innerHTML = item.icon;

          const label = document.createElement('p');
          Object.assign(label.style, {
            fontSize: '12px',
            fontWeight: '600',
            color: '#f0dfc0',
            margin: '0 0 4px',
          });
          label.textContent = item.label;

          const value = document.createElement('p');
          Object.assign(value.style, {
            fontSize: '11px',
            color: '#c9b48d',
            margin: '0',
            wordBreak: 'break-word',
            lineHeight: '1.4',
          });
          value.textContent = item.value;

          col.appendChild(iconWrap);
          col.appendChild(label);
          col.appendChild(value);
          columns.appendChild(col);
        });

        wrap.appendChild(columns);

        const footer = document.createElement('div');
        Object.assign(footer.style, {
          display: 'flex',
          alignItems: 'center',
          gap: '8px',
          borderTop: '1px solid rgba(255, 184, 119, 0.15)',
          paddingTop: '14px',
          fontFamily: "Georgia, 'Times New Roman', serif",
          fontStyle: 'italic',
          fontSize: '12px',
          color: '#c9b48d',
        });
        footer.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#ffb877" stroke-width="2" stroke-linecap="round"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg><span>Let\u2019s create something amazing together.</span>';
        wrap.appendChild(footer);

        return wrap;
      }

      function showContent(chapter) {
        const content = chapterContent[chapter.id];
        contentEyebrow.textContent = content.eyebrow || '';
        contentTitle.textContent = content.title;
        contentSubtitle.textContent = content.subtitle || '';
        contentBody.innerHTML = '';

        let rendered;
        if (content.type === 'journal') rendered = renderJournal(content.entries);
        else if (content.type === 'journey') rendered = renderJourney(content.entries);
        else if (content.type === 'skills') rendered = renderSkills();
        else if (content.type === 'about') rendered = renderAbout();
        else if (content.type === 'contact') rendered = renderContact();

        contentBody.appendChild(rendered);

        if (content.type === 'journey' && rendered.__selectDefault) {
          requestAnimationFrame(() => rendered.__selectDefault());
        }

        contentPanel.classList.add('visible');
        clampPanelHeight();
      }

      function hideContent() {
        contentPanel.classList.remove('visible');
      }

      function updateNavUI() {
        document.querySelectorAll('.chapter-btn').forEach((btn, i) => {
          btn.classList.toggle('active', i === currentIndex);
        });
      }

      function goToIndex(i) {
        currentIndex = Math.max(0, Math.min(chapters.length - 1, i));
        hideContent();
        cameraController.goTo(chapters[currentIndex], 2, () => {
          showContent(chapters[currentIndex]);

          if (openIndex !== null && openIndex !== currentIndex && markers[openIndex].userData.onClose) {
            markers[openIndex].userData.onClose();
            openIndex = null;
          }

          if (markers[currentIndex].userData.onOpen) {
            markers[currentIndex].userData.onOpen();
            if (markers[currentIndex].userData.onClose) {
              openIndex = currentIndex;
            }
          }
        });
        updateNavUI();
      }

      setupMarkerInteraction(camera, renderer, markers, goToIndex);

      // Loading overlay — brief, masks initial scene setup
      const loadingOverlay = document.getElementById('loading-overlay');
      setTimeout(() => {
        loadingOverlay.classList.add('hidden');
      }, 400);

      // Onboarding hint — fades in once and stays visible permanently
      const onboardingHint = document.getElementById('onboarding-hint');
      setTimeout(() => {
        onboardingHint.classList.add('visible');
      }, 900);

      document.querySelectorAll('.chapter-btn').forEach((btn, i) => {
        btn.addEventListener('click', () => goToIndex(i));
      });

      window.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowRight') goToIndex(currentIndex + 1);
        if (e.key === 'ArrowLeft') goToIndex(currentIndex - 1);
      });

      cameraController.goTo(chapters[0], 0, () => {
        showContent(chapters[0]);
      });
      updateNavUI();
    </script>
  </body>
</html>
